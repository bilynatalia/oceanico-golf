---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
---

<BaseLayout title="404 - Page Not Found | Oceanico Golf">
  <div
    class="min-h-screen bg-oceanico-green flex items-center justify-center text-white text-center px-4"
  >
    <div>
      <h1 class="font-serif text-9xl font-bold text-oceanico-gold mb-4">404</h1>
      <h2 class="font-serif text-3xl mb-4">Lost in the Rough</h2>
      <p class="text-gray-300 mb-8 max-w-md mx-auto">
        It seems you've hit your ball into an area we can't find. Let's get you
        back on the fairway.
      </p>
      <a
        href="/"
        class="inline-block bg-oceanico-gold text-white px-8 py-3 font-bold uppercase tracking-widest hover:bg-yellow-600 transition"
      >
        Back to Home
      </a>
    </div>
  </div>
</BaseLayout>
