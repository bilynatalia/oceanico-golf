---
import BaseLayout from "../layouts/BaseLayout.astro";
import TopBar from "../components/TopBar.svelte";
import Navigation from "../components/Navigation.svelte";
import Footer from "../components/Footer.svelte";
import "../styles/global.css";
---

<BaseLayout
  title="Agents Portal | Oceanico Golf"
  description="Access the Oceanico Golf agents portal for exclusive rates, booking tools, and partner resources for travel agents and tour operators."
>
  <TopBar client:load />
  <Navigation client:load />

  <!-- Hero Section -->
  <section class="bg-oceanico-green py-20 text-white text-center">
    <div class="container mx-auto px-4">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">
        Agents Portal
      </h1>
      <p class="text-oceanico-gold uppercase tracking-widest text-sm mb-4">
        Partner With Oceanico Golf
      </p>
      <p class="text-lg max-w-2xl mx-auto text-gray-200">
        Access exclusive rates and booking tools for travel agents and tour
        operators.
      </p>
    </div>
  </section>

  <!-- Login Section -->
  <section class="py-20 bg-oceanico-light">
    <div class="container mx-auto px-4">
      <div class="max-w-md mx-auto">
        <div class="bg-white shadow-lg p-8">
          <h2
            class="font-serif text-2xl text-oceanico-green font-bold mb-6 text-center"
          >
            Agent Login
          </h2>
          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1"
                >Username / Email</label
              >
              <input
                type="text"
                class="w-full border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-oceanico-gold focus:border-transparent"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1"
                >Password</label
              >
              <input
                type="password"
                class="w-full border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-oceanico-gold focus:border-transparent"
              />
            </div>
            <button
              type="submit"
              class="w-full bg-oceanico-gold text-white py-3 font-bold uppercase tracking-wider hover:bg-oceanico-green transition"
            >
              Login
            </button>
          </form>
          <div class="mt-4 text-center text-sm">
            <a href="#" class="text-oceanico-green hover:text-oceanico-gold"
              >Forgot your password?</a
            >
          </div>
        </div>

        <!-- Create Account -->
        <div class="mt-8 bg-white shadow-lg p-8 text-center">
          <h3 class="font-serif text-xl text-oceanico-green font-bold mb-4">
            Not registered yet?
          </h3>
          <p class="text-gray-600 mb-6">
            Become an Oceanico Golf partner and access exclusive rates and
            booking tools.
          </p>
          <a
            href="/contact-us/"
            class="inline-block bg-oceanico-green text-white px-8 py-3 font-bold uppercase tracking-wider hover:bg-oceanico-gold transition"
          >
            Create Account
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="font-serif text-3xl text-oceanico-green font-bold mb-8">
        Agent Benefits
      </h2>
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div>
          <div class="text-oceanico-gold text-4xl mb-4">💰</div>
          <h3 class="font-bold text-lg mb-2">Competitive Rates</h3>
          <p class="text-gray-600">
            Access exclusive agent rates on all green fees and packages.
          </p>
        </div>
        <div>
          <div class="text-oceanico-gold text-4xl mb-4">📊</div>
          <h3 class="font-bold text-lg mb-2">Easy Booking</h3>
          <p class="text-gray-600">
            Use our dedicated booking system for quick reservations.
          </p>
        </div>
        <div>
          <div class="text-oceanico-gold text-4xl mb-4">🤝</div>
          <h3 class="font-bold text-lg mb-2">Dedicated Support</h3>
          <p class="text-gray-600">
            Get personalized assistance from our agents team.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer client:visible />
</BaseLayout>
