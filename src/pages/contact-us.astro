---
import BaseLayout from "../layouts/BaseLayout.astro";
import TopBar from "../components/TopBar.svelte";
import Navigation from "../components/Navigation.svelte";
import Footer from "../components/Footer.svelte";
import "../styles/global.css";
---

<BaseLayout
  title="Contact Us | Oceanico Golf"
  description="Get in touch with Oceanico Golf. Contact our team for bookings, inquiries, and golf packages in the Algarve, Portugal."
>
  <TopBar client:load />
  <Navigation client:load />

  <!-- Hero Section -->
  <section class="bg-oceanico-green py-20 text-white text-center">
    <div class="container mx-auto px-4">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
      <p class="text-oceanico-gold uppercase tracking-widest text-sm mb-4">
        We'd Love to Hear From You
      </p>
      <p class="text-lg max-w-2xl mx-auto text-gray-200">
        Whether you're planning your next golf trip or have questions about our
        courses, our team is here to help.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-20 bg-oceanico-light">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div class="bg-white p-8 shadow-lg">
          <h2 class="font-serif text-2xl text-oceanico-green font-bold mb-6">
            Send Us a Message
          </h2>
          <form class="space-y-6">
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2"
                  >First Name</label
                >
                <input
                  type="text"
                  class="w-full px-4 py-3 border border-gray-300 focus:border-oceanico-gold focus:outline-none"
                  placeholder="John"
                />
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2"
                  >Last Name</label
                >
                <input
                  type="text"
                  class="w-full px-4 py-3 border border-gray-300 focus:border-oceanico-gold focus:outline-none"
                  placeholder="Doe"
                />
              </div>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2"
                >Email</label
              >
              <input
                type="email"
                class="w-full px-4 py-3 border border-gray-300 focus:border-oceanico-gold focus:outline-none"
                placeholder="john@example.com"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2"
                >Phone</label
              >
              <input
                type="tel"
                class="w-full px-4 py-3 border border-gray-300 focus:border-oceanico-gold focus:outline-none"
                placeholder="+351 XXX XXX XXX"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2"
                >Subject</label
              >
              <select
                class="w-full px-4 py-3 border border-gray-300 focus:border-oceanico-gold focus:outline-none"
              >
                <option>General Inquiry</option>
                <option>Booking Request</option>
                <option>Corporate Events</option>
                <option>Tournaments</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2"
                >Message</label
              >
              <textarea
                rows="5"
                class="w-full px-4 py-3 border border-gray-300 focus:border-oceanico-gold focus:outline-none"
                placeholder="How can we help you?"></textarea>
            </div>
            <button
              type="submit"
              class="w-full bg-oceanico-gold text-white py-3 font-bold uppercase tracking-widest hover:bg-oceanico-green transition"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="font-serif text-2xl text-oceanico-green font-bold mb-6">
            Get in Touch
          </h2>

          <div class="space-y-8">
            <div>
              <h3 class="font-semibold text-oceanico-gold mb-2">Address</h3>
              <p class="text-gray-600">
                Oceanico Golf<br />Vilamoura, Algarve<br />Portugal
              </p>
            </div>

            <div>
              <h3 class="font-semibold text-oceanico-gold mb-2">Phone</h3>
              <p class="text-gray-600">+351 289 123 456</p>
            </div>

            <div>
              <h3 class="font-semibold text-oceanico-gold mb-2">Email</h3>
              <p class="text-gray-600">info@oceanicogolf.com</p>
            </div>

            <div>
              <h3 class="font-semibold text-oceanico-gold mb-2">
                Office Hours
              </h3>
              <p class="text-gray-600">
                Monday - Friday: 8:00 AM - 6:00 PM<br />
                Saturday - Sunday: 7:00 AM - 7:00 PM
              </p>
            </div>
          </div>

          <!-- Map Placeholder -->
          <div class="mt-8 bg-gray-200 h-64 flex items-center justify-center">
            <p class="text-gray-500">Map - Vilamoura, Algarve</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer client:visible />
</BaseLayout>
