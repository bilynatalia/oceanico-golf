---
import BaseLayout from "../layouts/BaseLayout.astro";
import TopBar from "../components/TopBar.svelte";
import Navigation from "../components/Navigation.svelte";
import Footer from "../components/Footer.svelte";
import "../styles/global.css";
---

<BaseLayout
  title="Gift Vouchers | Oceanico Golf"
  description="Purchase Oceanico Golf gift vouchers for green fees, equipment hire, golf tuition or pro shop merchandise at our five championship courses in Vilamoura, Algarve."
>
  <TopBar client:load />
  <Navigation client:load />

  <!-- Hero Section -->
  <section class="bg-oceanico-green py-20 text-white text-center">
    <div class="container mx-auto px-4">
      <h1 class="font-serif text-4xl md:text-5xl font-bold mb-4">
        Gift Vouchers
      </h1>
      <p class="text-oceanico-gold uppercase tracking-widest text-sm mb-4">
        The Perfect Gift for Golf Lovers
      </p>
      <p class="text-lg max-w-2xl mx-auto text-gray-200">
        Give the gift of an unforgettable golfing experience at one of Europe's
        finest golf destinations.
      </p>
    </div>
  </section>

  <!-- Gift Vouchers Info -->
  <section class="py-20 bg-oceanico-light">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
        <!-- Info Card -->
        <div class="bg-white shadow-lg p-8">
          <h2 class="font-serif text-2xl text-oceanico-green font-bold mb-4">
            Gift Vouchers from Oceanico Golf
          </h2>
          <p class="text-gray-600 mb-6">
            Gift Vouchers from Oceanico Golf can be redeemed at any of our five
            Vilamoura championship golf courses in the Algarve for:
          </p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-start text-gray-600">
              <span class="text-oceanico-gold mr-2">✓</span>
              Green Fees
            </li>
            <li class="flex items-start text-gray-600">
              <span class="text-oceanico-gold mr-2">✓</span>
              Equipment Hire
            </li>
            <li class="flex items-start text-gray-600">
              <span class="text-oceanico-gold mr-2">✓</span>
              Golf Tuition
            </li>
            <li class="flex items-start text-gray-600">
              <span class="text-oceanico-gold mr-2">✓</span>
              Pro Shop Merchandise
            </li>
          </ul>
          <p class="text-gray-600">
            To purchase a gift voucher, simply visit one of our pro shops or
            contact us using the form.
          </p>
        </div>

        <!-- Contact Form -->
        <div class="bg-white shadow-lg p-8">
          <h3 class="font-serif text-xl text-oceanico-green font-bold mb-6">
            Request a Gift Voucher
          </h3>
          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1"
                >Your Name</label
              >
              <input
                type="text"
                class="w-full border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-oceanico-gold focus:border-transparent"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1"
                >Email Address</label
              >
              <input
                type="email"
                class="w-full border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-oceanico-gold focus:border-transparent"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1"
                >Voucher Value (€)</label
              >
              <select
                class="w-full border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-oceanico-gold focus:border-transparent"
              >
                <option>€50</option>
                <option>€100</option>
                <option>€150</option>
                <option>€200</option>
                <option>€300</option>
                <option>€500</option>
                <option>Custom Amount</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1"
                >Message</label
              >
              <textarea
                rows="3"
                class="w-full border border-gray-300 px-4 py-2 focus:ring-2 focus:ring-oceanico-gold focus:border-transparent"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full bg-oceanico-gold text-white py-3 font-bold uppercase tracking-wider hover:bg-oceanico-green transition"
            >
              Request Voucher
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Terms -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 max-w-3xl">
      <h3 class="font-serif text-xl text-oceanico-green font-bold mb-4">
        Terms & Conditions
      </h3>
      <ul class="text-gray-600 space-y-2 text-sm">
        <li>• Vouchers cannot be redeemed for cash.</li>
        <li>• The voucher is valid for one year from the date of purchase.</li>
        <li>
          • Advanced booking recommended and confirmation is subject to
          availability.
        </li>
        <li>• Vouchers are personal and not transferable.</li>
        <li>
          • Vouchers cannot be redeemed for any service or product at the
          Clubhouse restaurants.
        </li>
      </ul>
    </div>
  </section>

  <Footer client:visible />
</BaseLayout>
